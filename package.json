{
  "name": "nera-cosmetique-web",
  "version": "1.0.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prebuild": "node -e \"if(process.platform!=='win32')require('child_process').execSync('chmod +x node_modules/.bin/ng',{stdio:'inherit'})\"",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:prod": "ng build --configuration production",
    "build:prod:netlify": "node scripts/set-api-url.js && ng build --configuration production",
    "postinstall": "node scripts/copy-fontawesome.js"
  },
  "private": true,
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.1",
    "@angular/animations": "^18.0.0",
    "@angular/common": "^18.0.0",
    "@angular/compiler": "^18.0.0",
    "@angular/core": "^18.0.0",
    "@angular/forms": "^18.0.0",
    "@angular/platform-browser": "^18.0.0",
    "@angular/platform-browser-dynamic": "^18.0.0",
    "@angular/router": "^18.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.0.0",
    "@angular/cli": "^18.0.0",
    "@angular/compiler-cli": "^18.0.0",
    "@types/jasmine": "~5.1.0",
    "typescript": "~5.4.2"
  }
}
