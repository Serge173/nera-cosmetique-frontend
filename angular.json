{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "nera-cosmetique-web": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/nera-cosmetique-web",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": ["src/favicon.ico", "src/assets"],
            "styles": ["src/styles.css", "src/assets/fontawesome/css/all.min.css"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [{
                "type": "initial",
                "maximumWarning": "500kb",
                "maximumError": "1mb"
              }],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "nera-cosmetique-web:build:production"
            },
            "development": {
              "buildTarget": "nera-cosmetique-web:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
